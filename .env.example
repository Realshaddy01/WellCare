# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_API_URL: The URL of your backend API (e.g., https://api.wellcare.com)
# Leave empty if the frontend and backend are on the same domain.
VITE_API_URL="https://well-care-backend.medhyas.com"

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=medhyas2_wellcare
